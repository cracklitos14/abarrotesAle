{
  "rewrites": [
    {
      "source": "/api/login",
      "destination": "https://abarrotesale.infinityfreeapp.com/backend-ale/index.php?endpoint=login"
    },
    {
      "source": "/api/products",
      "destination": "https://abarrotesale.infinityfreeapp.com/backend-ale/api/products.php"
    },
    {
      "source": "/api/dashboard",
      "destination": "https://abarrotesale.infinityfreeapp.com/backend-ale/api/dashboard.php"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://abarrotesale.infinityfreeapp.com/backend-ale/api/$1"
    },
    {
      "source": "/((?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}